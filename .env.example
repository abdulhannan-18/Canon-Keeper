# Copy this file to .env and fill in your values.
# NEVER commit the real .env — it is already in .gitignore.

# ── Server ────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of origins allowed to call this API from a browser.
# For local dev, the default below is fine.
CORS_ORIGIN=http://localhost:3000

# ── AI Provider ───────────────────────────────────────────────
# Which AI backend to use: "mock" | "watsonx" | "huggingface"
#
#   mock        → Zero setup. Smart pattern matching, no API key.
#                 Perfect while developing. Swap before submission.
#
#   huggingface → FREE! No credit card needed. Uses Hugging Face
#                 Inference API. Get a free API key at:
#                 https://huggingface.co/settings/tokens
#                 (Create a "Read" token — it's free, takes 1 minute)
#
#   watsonx     → IBM watsonx.ai with Granite. Required for the
#                 IBM SkillsBuild hackathon submission.
#
MODEL_PROVIDER=mock

# ── watsonx.ai (required only when MODEL_PROVIDER=watsonx) ────
# Sign up: https://www.ibm.com/watsonx
# If signup asks for a credit card, try cloud.ibm.com directly
# (the general free trial) — it often doesn't require a card.
# Hackathon organizers may also provide shared credentials.
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_REGION=us-south
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ── Hugging Face (required only when MODEL_PROVIDER=huggingface) ─
# FREE API key: https://huggingface.co/settings/tokens (Read token)
# Recommended model (free, powerful, great at JSON):
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_ID=mistralai/Mixtral-8x7B-Instruct-v0.1
